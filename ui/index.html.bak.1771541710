<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>Dashcam Viewer (v0.2)</title>

  <!-- MapLibre -->
  <link href="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.css" rel="stylesheet" />
  <script src="https://unpkg.com/maplibre-gl@4.7.1/dist/maplibre-gl.js"></script>

  <!-- Plotly -->
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js"></script>

  <style>
    :root { --bg:#0b0f14; --panel:#111823; --text:#e6edf3; --muted:#9fb0c0; --border:#253244; --danger:#ff6b6b; }
    body { margin:0; font-family: system-ui, -apple-system, Segoe UI, Roboto, sans-serif; background:var(--bg); color:var(--text); }
    header { padding:12px 16px; border-bottom:1px solid var(--border); display:flex; gap:12px; align-items:center; }
    header .title { font-weight:650; }
    header .muted { color:var(--muted); font-size:12px; }
    select, button, input[type="range"] { font:inherit; }
    select, button { background:var(--panel); color:var(--text); border:1px solid var(--border); border-radius:10px; padding:8px 10px; }
    button { cursor:pointer; }
    button:disabled { opacity:0.55; cursor:not-allowed; }
    .grid { display:grid; grid-template-columns: 440px 1fr; gap:12px; padding:12px; height: calc(100vh - 60px); box-sizing:border-box; }
    .card { background:var(--panel); border:1px solid var(--border); border-radius:14px; padding:12px; box-sizing:border-box; }
    .left { display:flex; flex-direction:column; gap:12px; overflow:auto; }
    .row { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
    .kv { font-size:12px; color:var(--muted); line-height:1.45; }
    .kv b { color:var(--text); font-weight:600; }
    #map { width:100%; height:100%; border-radius:14px; overflow:hidden; }
    .right { display:grid; grid-template-rows: 1fr 340px; gap:12px; min-height:0; }
    #chart { width:100%; height:100%; }
    .scrub { display:flex; flex-direction:column; gap:8px; }
    .scrub .time { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size:12px; color:var(--muted); }
    input[type="range"] { width:100%; }
    .small { font-size:12px; color:var(--muted); }
    .pill { display:inline-block; padding:2px 8px; border:1px solid var(--border); border-radius:999px; color:var(--muted); font-size:12px; }
    .split { display:grid; grid-template-columns: 1fr 1fr; gap:10px; margin-top:8px; }
    .kcell { border:1px solid var(--border); border-radius:12px; padding:10px; }
    .kcell .k { color:var(--muted); font-size:11px; }
    .kcell .v { font-size:14px; font-weight:650; color:var(--text); margin-top:2px; }
    .controls { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
    .toggle { display:flex; gap:8px; align-items:center; color:var(--muted); font-size:12px; }
    .toggle input { transform: translateY(1px); }
    .events { max-height: 32vh; overflow:auto; margin-top:10px; }
    .ev { border:1px solid var(--border); border-radius:12px; padding:8px 10px; margin-bottom:8px; cursor:pointer; }
    .ev:hover { border-color:#365070; }
    .ev .top { display:flex; justify-content:space-between; gap:8px; align-items:center; }
    .ev .ts { font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace; font-size:12px; color:var(--text); }
    .ev .type { font-size:12px; color:var(--muted); }
    .ev .sev { font-size:12px; color:var(--muted); }
    .ev .sub { margin-top:4px; color:var(--muted); font-size:11px; }
    .badge { display:inline-block; padding:2px 8px; border:1px solid var(--border); border-radius:999px; font-size:11px; color:var(--muted); }
  </style>
</head>
<body>
  <header>
    <div class="title">Dashcam Viewer <span class="pill">v0.2</span></div>
    <div class="muted" id="apiBase"></div>
  </header>

  <div class="grid">
    <div class="left">
      <div class="card">
        <div class="row">
          <select id="sessionSelect" style="flex:1; min-width: 280px;"></select>
          <button id="loadBtn" disabled>Load</button>
        </div>
        <div class="kv" id="sessionMeta" style="margin-top:10px;">
          <div><b>Session:</b> <span class="small">none loaded</span></div>
        </div>
      </div>

      <div class="card" id="summaryCard">
        <div class="row" style="justify-content:space-between;">
          <div><b>Summary</b></div>
          <div class="small" id="summaryUpdated">—</div>
        </div>
        <div class="split" id="summaryGrid">
          <div class="kcell"><div class="k">Distance</div><div class="v" id="sumDistance">—</div></div>
          <div class="kcell"><div class="k">Duration</div><div class="v" id="sumDuration">—</div></div>
          <div class="kcell"><div class="k">Max speed</div><div class="v" id="sumMaxSpeed">—</div></div>
          <div class="kcell"><div class="k">Avg / Moving avg</div><div class="v" id="sumAvgSpeed">—</div></div>
        </div>
        <div class="kv" style="margin-top:10px;" id="sumCounts">—</div>
      </div>

      <div class="card scrub">
        <div class="row" style="justify-content:space-between;">
          <div><b>Scrub</b> <span class="small">(uses /nearest)</span></div>
          <div class="time" id="scrubIso">—</div>
        </div>
        <input id="scrubSlider" type="range" min="0" max="0" step="200" value="0" disabled />
        <div class="kv" id="nearestInfo">
          <div><b>GNSS:</b> <span class="small">—</span></div>
          <div><b>Accel:</b> <span class="small">—</span></div>
          <div><b>Clip:</b> <span class="small">—</span></div>
        </div>
      </div>

      <div class="card">
        <div class="row" style="justify-content:space-between;">
          <div class="controls">
            <div><b>Events</b> <span class="small" id="eventCount">—</span></div>
            <label class="toggle"><input type="checkbox" id="toggleMapEvents" checked />Map dots</label>
            <label class="toggle"><input type="checkbox" id="toggleChartEvents" />Chart markers</label>
          </div>
        </div>
        <div class="events" id="eventList"></div>
      </div>

      <div class="card">
        <div class="row" style="justify-content:space-between;">
          <div><b>Clips</b></div>
          <div class="small" id="clipCount">—</div>
        </div>
        <div id="clipList" class="kv" style="margin-top:10px; max-height: 26vh; overflow:auto;"></div>
      </div>
    </div>

    <div class="right">
      <div class="card" style="padding:0;">
        <div id="map"></div>
      </div>
      <div class="card" style="padding:0;">
        <div id="chart"></div>
      </div>
    </div>
  </div>

<script>
(() => {
  const API = `${location.protocol}//${location.hostname}:8000`;
  document.getElementById("apiBase").textContent = `API: ${API}`;

  const elSessionSelect = document.getElementById("sessionSelect");
  const elLoadBtn = document.getElementById("loadBtn");
  const elSessionMeta = document.getElementById("sessionMeta");
  const elScrub = document.getElementById("scrubSlider");
  const elScrubIso = document.getElementById("scrubIso");
  const elNearestInfo = document.getElementById("nearestInfo");

  const elClipList = document.getElementById("clipList");
  const elClipCount = document.getElementById("clipCount");

  const elEventList = document.getElementById("eventList");
  const elEventCount = document.getElementById("eventCount");
  const elToggleMapEvents = document.getElementById("toggleMapEvents");
  const elToggleChartEvents = document.getElementById("toggleChartEvents");

  const elSumUpdated = document.getElementById("summaryUpdated");
  const elSumDistance = document.getElementById("sumDistance");
  const elSumDuration = document.getElementById("sumDuration");
  const elSumMaxSpeed = document.getElementById("sumMaxSpeed");
  const elSumAvgSpeed = document.getElementById("sumAvgSpeed");
  const elSumCounts = document.getElementById("sumCounts");

  let map, marker;
  let currentSession = null;
  let chartInitialized = false;
  let lastNearestReq = 0;
  let pendingNearestTimer = null;

  let currentEvents = [];
  let eventShapes = [];
  let cursorIso = null;

  const TYPE_ORDER = ["hard_brake","hard_accel","harsh_turn","stop","bump"];

  function typeColor(t) {
    // Keep it consistent across map + chart + list
    switch (t) {
      case "hard_brake": return "#ff6b6b";
      case "hard_accel": return "#ffd166";
      case "harsh_turn": return "#4dabf7";
      case "stop": return "#adb5bd";
      case "bump": return "#69db7c";
      default: return "#9fb0c0";
    }
  }

  // Keep our own layout object (avoid Plotly.d3)
  const chartLayout = {
    margin: { l: 50, r: 20, t: 20, b: 45 },
    xaxis: { title: "Time (UTC)" },
    yaxis: { title: "Accel (raw units)" },
    showlegend: true,
    shapes: []
  };
  const chartConfig = { displayModeBar: false, responsive: true };

  async function apiGet(path) {
    const r = await fetch(API + path);
    if (!r.ok) throw new Error(`${r.status} ${r.statusText} for ${path}`);
    return await r.json();
  }

  function fmtMi(mi) {
    if (mi == null) return "—";
    return `${mi.toFixed(2)} mi`;
  }
  function fmtMph(v) {
    if (v == null) return "—";
    return `${v.toFixed(1)} mph`;
  }
  function fmtDuration(sec) {
    if (sec == null) return "—";
    const s = Math.max(0, Math.floor(sec));
    const hh = String(Math.floor(s/3600)).padStart(2,"0");
    const mm = String(Math.floor((s%3600)/60)).padStart(2,"0");
    const ss = String(s%60).padStart(2,"0");
    return `${hh}:${mm}:${ss}`;
  }

  function initMap() {
    const osmStyle = {
      version: 8,
      sources: {
        osm: {
          type: "raster",
          tiles: ["https://tile.openstreetmap.org/{z}/{x}/{y}.png"],
          tileSize: 256,
          attribution: "© OpenStreetMap contributors"
        }
      },
      layers: [{ id: "osm", type: "raster", source: "osm" }]
    };

    map = new maplibregl.Map({
      container: "map",
      style: osmStyle,
      center: [-97.12, 33.16],
      zoom: 13
    });

    map.addControl(new maplibregl.NavigationControl(), "top-right");
    marker = new maplibregl.Marker({ draggable: false }).setLngLat([-97.12, 33.16]).addTo(map);
  }

  function setTrack(geojsonFeature) {
    const layerId = "track";
    const srcId = "track-src";

    if (map.getLayer(layerId)) map.removeLayer(layerId);
    if (map.getSource(srcId)) map.removeSource(srcId);

    map.addSource(srcId, { type: "geojson", data: geojsonFeature });
    map.addLayer({
      id: layerId,
      type: "line",
      source: srcId,
      paint: { "line-width": 4 }
    });

    const coords = geojsonFeature?.geometry?.coordinates || [];
    if (coords.length >= 2) {
      let minLon=coords[0][0], maxLon=coords[0][0], minLat=coords[0][1], maxLat=coords[0][1];
      for (const [lon, lat] of coords) {
        if (lon < minLon) minLon = lon;
        if (lon > maxLon) maxLon = lon;
        if (lat < minLat) minLat = lat;
        if (lat > maxLat) maxLat = lat;
      }
      map.fitBounds([[minLon, minLat],[maxLon, maxLat]], { padding: 40, duration: 400 });
    }
  }

  function setEventMarkers(events) {
    const srcId = "events-src";
    const layerId = "events-layer";

    if (map.getLayer(layerId)) map.removeLayer(layerId);
    if (map.getSource(srcId)) map.removeSource(srcId);

    const features = (events || [])
      .filter(e => e.lon != null && e.lat != null)
      .map(e => ({
        type: "Feature",
        geometry: { type: "Point", coordinates: [e.lon, e.lat] },
        properties: {
          event_id: e.event_id,
          ts_utc: e.ts_utc,
          event_type: e.event_type,
          severity: e.severity
        }
      }));

    map.addSource(srcId, { type: "geojson", data: { type: "FeatureCollection", features } });

    map.addLayer({
      id: layerId,
      type: "circle",
      source: srcId,
      paint: {
        "circle-radius": 5,
        "circle-stroke-width": 1,
        "circle-opacity": 0.85,
        "circle-color": [
          "match", ["get","event_type"],
          "hard_brake", typeColor("hard_brake"),
          "hard_accel", typeColor("hard_accel"),
          "harsh_turn", typeColor("harsh_turn"),
          "stop", typeColor("stop"),
          "bump", typeColor("bump"),
          "#9fb0c0"
        ]
      }
    });

    map.on("click", layerId, (ev) => {
      const f = ev.features && ev.features[0];
      if (!f) return;
      const p = f.properties || {};
      const c = f.geometry?.coordinates;
      const html = `
        <div style="font-size:12px;">
          <div><b>${p.event_type}</b> <span style="color:#9fb0c0;">sev=${Number(p.severity||0).toFixed(2)}</span></div>
          <div style="color:#9fb0c0; margin-top:2px;">${p.ts_utc}</div>
        </div>`;
      new maplibregl.Popup().setLngLat(c).setHTML(html).addTo(map);
    });
  }

  function initChart() {
    Plotly.newPlot("chart", [], chartLayout, chartConfig);
    chartInitialized = true;
  }

  function plotAccel(series) {
    const x = series.map(p => p.ts_utc);
    const mag = series.map(p => p.a_mag_raw);
    const ax = series.map(p => p.ax);
    const ay = series.map(p => p.ay);
    const az = series.map(p => p.az);

    const traces = [
      { x, y: mag, mode: "lines", name: "a_mag_raw", type: "scattergl" },
      { x, y: ax,  mode: "lines", name: "ax",        type: "scattergl", visible: "legendonly" },
      { x, y: ay,  mode: "lines", name: "ay",        type: "scattergl", visible: "legendonly" },
      { x, y: az,  mode: "lines", name: "az",        type: "scattergl", visible: "legendonly" },
    ];

    Plotly.react("chart", traces, chartLayout, chartConfig);
  }

  function rebuildEventShapes() {
    eventShapes = (currentEvents || [])
      .filter(e => e.ts_utc)
      .map(e => ({
        type: "line",
        xref: "x",
        yref: "paper",
        x0: e.ts_utc, x1: e.ts_utc,
        y0: 0, y1: 1,
        line: { width: 1, dash: "dot", color: typeColor(e.event_type) }
      }));
  }

  function renderChartShapes() {
    const shapes = [];
    if (elToggleChartEvents.checked) shapes.push(...eventShapes);
    if (cursorIso) shapes.push({
      type: "line",
      xref: "x",
      yref: "paper",
      x0: cursorIso, x1: cursorIso,
      y0: 0, y1: 1,
      line: { width: 2 }
    });
    Plotly.relayout("chart", { shapes });
  }

  function setChartCursor(tsIso) {
    cursorIso = tsIso;
    renderChartShapes();
  }

  function setClipList(clips) {
    elClipCount.textContent = `${clips.length} clips`;
    elClipList.innerHTML = clips.map(c => {
      const s = c.start_ts_utc ? c.start_ts_utc.replace("+00:00","Z") : "—";
      const e = c.end_ts_utc ? c.end_ts_utc.replace("+00:00","Z") : "—";
      return `<div style="margin-bottom:8px;">
        <b>${c.channel}</b> ${c.clip_name}<br/>
        <span class="small">${s} → ${e}</span>
      </div>`;
    }).join("");
  }

  function setSessionMeta(s, clips) {
    const sync = s.time_sync || {};
    elSessionMeta.innerHTML = `
      <div><b>Session:</b> <span class="small">${s.drive_session_id}</span></div>
      <div><b>Vehicle:</b> <span class="small">${s.vehicle_tag || "—"}</span></div>
      <div><b>Start:</b> <span class="small">${s.start_ts_utc || "—"}</span></div>
      <div><b>End:</b> <span class="small">${s.end_ts_utc || "—"}</span></div>
      <div><b>time_sync:</b> <span class="small">slope=${(sync.slope ?? "—")} p95_ms=${(sync.residual_p95_ms ?? "—")}</span></div>
      <div><b>Clips:</b> <span class="small">${clips.length}</span></div>
    `;
  }

  function setSummaryCard(sum) {
    if (!sum) {
      elSumUpdated.textContent = "—";
      elSumDistance.textContent = "—";
      elSumDuration.textContent = "—";
      elSumMaxSpeed.textContent = "—";
      elSumAvgSpeed.textContent = "—";
      elSumCounts.innerHTML = `<span class="badge">Summary not found (run refresh_derived)</span>`;
      return;
    }

    elSumUpdated.textContent = sum.updated_at ? `updated ${sum.updated_at}` : "—";
    elSumDistance.textContent = fmtMi(sum.distance_mi);
    elSumDuration.textContent = fmtDuration(sum.duration_s);
    elSumMaxSpeed.textContent = fmtMph(sum.max_speed_mph);
    elSumAvgSpeed.textContent = `${fmtMph(sum.avg_speed_mph)} / ${fmtMph(sum.moving_avg_speed_mph)}`;

    elSumCounts.innerHTML = `
      <div><b>Stops:</b> ${sum.stops_count ?? 0} &nbsp; <b>Bumps:</b> ${sum.bump_count ?? 0}</div>
      <div><b>Hard brake:</b> ${sum.hard_brake_count ?? 0} &nbsp; <b>Hard accel:</b> ${sum.hard_accel_count ?? 0} &nbsp; <b>Harsh turn:</b> ${sum.harsh_turn_count ?? 0}</div>
      <div class="small" style="margin-top:6px;">params: ${sum.params ? JSON.stringify(sum.params) : "—"}</div>
    `;
  }

  function setEventList(events) {
    const n = events.length;
    elEventCount.textContent = `(${n})`;

    // sort by ts, then type order (stable)
    const sorted = [...events].sort((a,b) => {
      const ta = Date.parse(a.ts_utc || 0), tb = Date.parse(b.ts_utc || 0);
      if (ta !== tb) return ta - tb;
      return TYPE_ORDER.indexOf(a.event_type) - TYPE_ORDER.indexOf(b.event_type);
    });

    elEventList.innerHTML = sorted.map(e => {
      const sev = (e.severity == null) ? "—" : Number(e.severity).toFixed(2);
      const c = typeColor(e.event_type);
      const coord = (e.lat != null && e.lon != null) ? `${e.lat.toFixed(6)}, ${e.lon.toFixed(6)}` : "—";
      return `
        <div class="ev" data-ts="${e.ts_utc}" data-lat="${e.lat ?? ""}" data-lon="${e.lon ?? ""}">
          <div class="top">
            <div>
              <span class="badge" style="border-color:${c}; color:${c};">${e.event_type}</span>
              <span class="ts" style="margin-left:8px;">${e.ts_utc}</span>
            </div>
            <div class="sev">sev=${sev}</div>
          </div>
          <div class="sub">${coord}</div>
        </div>
      `;
    }).join("");

    // click -> jump scrub + map + cursor
    for (const node of elEventList.querySelectorAll(".ev")) {
      node.addEventListener("click", async () => {
        const tsIso = node.getAttribute("data-ts");
        if (!tsIso) return;
        const tsMs = Date.parse(tsIso);
        if (!Number.isFinite(tsMs)) return;

        // move scrub
        elScrub.value = String(tsMs);
        elScrubIso.textContent = new Date(tsMs).toISOString();
        setChartCursor(new Date(tsMs).toISOString());

        // move marker to event coords if present, else nearest GNSS
        const lat = Number(node.getAttribute("data-lat"));
        const lon = Number(node.getAttribute("data-lon"));
        if (Number.isFinite(lat) && Number.isFinite(lon) && map && marker) {
          marker.setLngLat([lon, lat]);
          map.easeTo({ center: [lon, lat], duration: 250 });
        }
        await fetchNearest(tsMs).catch(console.error);
      });
    }
  }

  function enableScrub(startIso, endIso) {
    const startMs = Date.parse(startIso);
    const endMs = Date.parse(endIso);
    elScrub.min = String(startMs);
    elScrub.max = String(endMs);
    elScrub.step = "200"; // 5Hz buckets
    elScrub.value = String(startMs);
    elScrub.disabled = false;

    const tsIso = new Date(startMs).toISOString();
    elScrubIso.textContent = tsIso;
    setChartCursor(tsIso);
  }

  async function fetchNearest(tsMs) {
    const now = Date.now();
    if (now - lastNearestReq < 200) return;
    lastNearestReq = now;

    const tsIso = new Date(Number(tsMs)).toISOString();
    elScrubIso.textContent = tsIso;
    setChartCursor(tsIso);

    const sid = currentSession?.drive_session_id;
    if (!sid) return;

    const data = await apiGet(`/sessions/${sid}/nearest?ts=${encodeURIComponent(tsIso)}`);

    if (data.gnss?.lon != null && data.gnss?.lat != null) {
      marker.setLngLat([data.gnss.lon, data.gnss.lat]);
    }

    elNearestInfo.innerHTML = `
      <div><b>GNSS:</b> <span class="small">${data.gnss ? `${data.gnss.ts_utc}  (${data.gnss.lat.toFixed(6)}, ${data.gnss.lon.toFixed(6)})  ${Math.round(data.gnss.speed_mph)} mph` : "—"}</span></div>
      <div><b>Accel:</b> <span class="small">${data.accel ? `${data.accel.ts_utc}  a_mag=${data.accel.a_mag_raw.toFixed(2)}  ax=${data.accel.ax.toFixed(1)} ay=${data.accel.ay.toFixed(1)} az=${data.accel.az.toFixed(1)}` : "—"}</span></div>
      <div><b>Clip:</b> <span class="small">${data.clip ? `${data.clip.clip_name}  (${data.clip.start_ts_utc} → ${data.clip.end_ts_utc})` : "—"}</span></div>
    `;
  }

  function onScrubInput(ev) {
    const v = ev.target.value;
    if (pendingNearestTimer) clearTimeout(pendingNearestTimer);
    pendingNearestTimer = setTimeout(() => fetchNearest(v).catch(console.error), 80);
  }

  async function loadSessions() {
    const sessions = await apiGet("/sessions");

    // Prefer sessions that have start_ts_utc
    const usable = sessions.filter(s => s.start_ts_utc);
    const list = usable.length ? usable : sessions;

    elSessionSelect.innerHTML = list.map(s =>
      `<option value="${s.drive_session_id}">${(s.vehicle_tag||"—")}  ${s.start_ts_utc || "(no start)"}  ${s.drive_session_id.slice(0,8)}</option>`
    ).join("");

    elLoadBtn.disabled = list.length === 0;
    if (list.length > 0) elSessionSelect.value = list[0].drive_session_id;
  }

  async function loadSession(sessionId) {
    if (!sessionId) throw new Error("No session selected");
    elLoadBtn.disabled = true;

    try {
      const s = await apiGet(`/sessions/${sessionId}`);
      const clips = await apiGet(`/sessions/${sessionId}/clips`);
      const track = await apiGet(`/sessions/${sessionId}/track`);

      currentSession = s;
      setSessionMeta(s, clips);
      setClipList(clips);

      if (!map) initMap();
      map.once("load", () => setTrack(track));
      if (map.loaded()) setTrack(track);

      // Summary + Events (now include lat/lon)
      let summary = null;
      try {
        summary = await apiGet(`/sessions/${sessionId}/summary`);
      } catch (e) {
        summary = null;
      }
      setSummaryCard(summary);

      const evTypes = TYPE_ORDER.join(",");
      currentEvents = await apiGet(`/sessions/${sessionId}/events?types=${encodeURIComponent(evTypes)}&limit=5000`);
      setEventList(currentEvents);

      if (map.loaded() && elToggleMapEvents.checked) setEventMarkers(currentEvents);

      if (!chartInitialized) initChart();
      const accel = await apiGet(`/sessions/${sessionId}/accel?start=${encodeURIComponent(s.start_ts_utc.replace("+00:00","Z"))}&end=${encodeURIComponent(s.end_ts_utc.replace("+00:00","Z"))}&limit=200000`);
      plotAccel(accel);

      rebuildEventShapes();
      renderChartShapes();

      enableScrub(s.start_ts_utc, s.end_ts_utc);
      await fetchNearest(Date.parse(s.start_ts_utc));
    } finally {
      elLoadBtn.disabled = false;
    }
  }

  elToggleMapEvents.addEventListener("change", () => {
    if (!map || !map.loaded()) return;
    if (elToggleMapEvents.checked) setEventMarkers(currentEvents);
    else {
      if (map.getLayer("events-layer")) map.removeLayer("events-layer");
      if (map.getSource("events-src")) map.removeSource("events-src");
    }
  });

  elToggleChartEvents.addEventListener("change", () => renderChartShapes());

  elLoadBtn.addEventListener("click", () => loadSession(elSessionSelect.value).catch(err => alert(err.message)));
  elScrub.addEventListener("input", onScrubInput);

  loadSessions().catch(err => alert(err.message));
})();
</script>
</body>
</html>
