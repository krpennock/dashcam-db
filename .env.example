# Database credentials
POSTGRES_DB=dashcam
POSTGRES_USER=dashcam
POSTGRES_PASSWORD=change_me

# Timezone
TZ=UTC

# Host path to the dashcam import directory.
# Used by docker-compose (ingest service mount) and scripts/dashcam_ingest_ready.sh.
# Default (if unset): ./import (repo-local, for development)
# IMPORT_ROOT=/srv/dashcam/import
